# Normalize line endings: LF in the repo, CRLF on Windows checkout
* text=auto eol=lf

# Force Unix endings for these files regardless of OS
*.py   text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.toml text eol=lf
*.cfg  text eol=lf
*.txt  text eol=lf
*.json text eol=lf
*.sh   text eol=lf

# Binary files — never touch line endings
*.h5     binary
*.pkl    binary
*.png    binary
*.svg    binary
